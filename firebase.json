{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "out",
    "site": "mycyberclinics-main",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/studio",
        "destination": "/studio/index.html"
      },
      {
        "source": "/studio/**",
        "destination": "/studio/index.html"
      }
    ]
  }
}
